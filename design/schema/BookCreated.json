{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/book-tracker/BookCreated",
  "title": "BookCreated",
  "description": "ALPSプロファイルのBookCreated状態に対応する。doRegisterBook の結果。初期status は常に unread。",
  "type": "object",
  "required": ["bookId", "bookTitle", "authorName", "genre", "status"],
  "properties": {
    "bookId": {
      "type": "string",
      "description": "生成された本の識別子",
      "minLength": 1,
      "maxLength": 50
    },
    "bookTitle": {
      "type": "string",
      "description": "本のタイトル",
      "minLength": 1,
      "maxLength": 60
    },
    "authorName": {
      "type": "string",
      "description": "著者名",
      "minLength": 1,
      "maxLength": 50
    },
    "genre": {
      "type": "string",
      "description": "ジャンル",
      "minLength": 1,
      "maxLength": 20
    },
    "isbn": {
      "type": ["string", "null"],
      "description": "ISBN-13番号。不明な場合はnull。",
      "pattern": "^97[89]-[0-9]-[0-9]{2}-[0-9]{6}-[0-9]$"
    },
    "status": {
      "type": "string",
      "description": "登録直後は常に unread",
      "const": "unread"
    },
    "_links": {
      "type": "object",
      "properties": {
        "goBookList": { "$ref": "#/$defs/link" },
        "goBookItem": { "$ref": "#/$defs/link" },
        "doStartReading": { "$ref": "#/$defs/link" }
      }
    }
  },
  "$defs": {
    "link": {
      "type": "object",
      "required": ["href"],
      "properties": {
        "href": { "type": "string", "format": "uri-reference" }
      }
    }
  }
}
